        { "match": "^320-R(\\d+)$", "replace": "320 RSC-R$1"  }
      ]
    },
    "330 Riverside Crescent": {
      "sf_project": "Sobha Hartland -II",
      "sf_sub_project": "330 Riverside Crescent",
      "sf_unit_prefix": "",
      "match_scope": "sub_project",
      "unitTransforms": [
        { "match": "^(\\d+)$",      "replace": "330 RSC-$1"   },
        { "match": "^330-R(\\d+)$", "replace": "330 RSC-R$1"  }
      ]
    },
    "340 Riverside Crescent": {
      "sf_project": "Sobha Hartland -II",
      "sf_sub_project": "340 Riverside Crescent",
      "sf_unit_prefix": "",
      "match_scope": "sub_project",
      "unitTransforms": [
        { "match": "^(\\d+)$",      "replace": "340 RSC-$1"   },
        { "match": "^340-R(\\d+)$", "replace": "340 RSC-R$1"  }
      ]
    },
    "350 Riverside Crescent": {
      "sf_project": "Sobha Hartland -II",
      "sf_sub_project": "350 Riverside Crescent",
      "sf_unit_prefix": "",
      "match_scope": "sub_project",
      "unitTransforms": [
        { "match": "^(\\d+)$",      "replace": "350 RSC-$1"   },
        { "match": "^350-R(\\d+)$", "replace": "350 RSC-R$1"  }
      ]
    },
    "360 Riverside Crescent": {
      "sf_project": "Sobha Hartland -II",
      "sf_sub_project": "360 Riverside Crescent",
      "sf_unit_prefix": "",
      "match_scope": "sub_project",
      "unitTransforms": [
        { "match": "^(\\d+)$",      "replace": "360 RSC-$1"   },
        { "match": "^360-R(\\d+)$", "replace": "360 RSC-R$1"  }
      ]
    },

    "Sobha Creek Vistas Heights": {
      "sf_project": "Sobha Hartland",
      "sf_sub_project": "Sobha Creek Vista Heights",
      "sf_unit_prefix": "",
      "match_scope": "sub_project",
      "buildingTransforms": {
        "Sobha Creek Vista Heights - Tower A": [ { "match": "^(\\d+)$", "replace": "CVH-A$1" } ],
        "Sobha Creek Vista Heights - Tower B": [ { "match": "^(\\d+)$", "replace": "CVH-B$1" } ]
      }
    },
    "Sobha Creek vistas Reserve": {
      "sf_project": "Sobha Hartland",
      "sf_sub_project": "Sobha Creek vistas Reserve",
      "sf_unit_prefix": "",
      "match_scope": "sub_project",
      "unitTransforms": [
        { "match": "^A(\\d+)$", "replace": "RA-$1" },
        { "match": "^B(\\d+)$", "replace": "RB-$1" }
      ]
    },
    "Sobha Hartland Waves Opulence": {
      "sf_project": "Sobha Hartland",
      "sf_sub_project": "Sobha Waves Opulence",
      "sf_unit_prefix": "",
      "match_scope": "sub_project",
      "unitTransforms": [
        { "match": "^(\\d+)$", "replace": "WO-$1" },
        { "match": "^RETAIL\\s*(\\d+)$", "replace": "WO-R$1" }
      ]
    },
    "The Element at Sobha One": {
      "sf_project": "Sobha One",
      "sf_sub_project": "The Element at Sobha One",
      "sf_unit_prefix": "",
      "match_scope": "sub_project",
      "unitTransforms": [
        { "match": "^(\\d+)$", "replace": "SO-EL-$1" }
      ]
    },

    "_villa_note": "Projects below are villa/land-based. DLD uses plot numbers, SF uses villa numbers — they don't align by formula. Empty prefix + no transforms triggers plot-based compare (buyer + price fuzzy match).",
    "Sobha Reserve": {
      "sf_project": "Sobha Reserve",
      "sf_sub_project": "Sobha Reserve",
      "sf_unit_prefix": "",
      "match_scope": "sub_project"
    },
