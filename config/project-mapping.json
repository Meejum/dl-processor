{
  "_note": "Override auto-inferred DLD<->SF mapping per project. Keys = DLD project_name (exact). match_scope: 'sub_project' (default) | 'project'. unitTransforms: regex rewrites applied to the DLD unit_number. buildingTransforms: same, keyed by DLD building.name so multi-tower projects can translate per tower. If sf_unit_prefix is empty, the transform output is used as-is (used when SF includes the prefix like 'SO-A1001' or 'CGA1001'). defaults.areaThresholdPct: percent gap between DLD net_area and manual_area above which a row escalates to AREA_MISMATCH (otherwise A11 flag).",
  "defaults": {
    "areaThresholdPct": 5
  },
  "overrides": {
    "Sobha Hartland Waves": {
      "sf_project": "Sobha Hartland",
      "sf_sub_project": "Waves",
      "sf_unit_prefix": "W",
      "match_scope": "sub_project",
      "unitTransforms": [
        { "match": "^RETAIL\\s*(\\d+)$", "replace": "R$1" }
      ]
    },
    "Sobha Central Phase I": {
      "sf_project": "Sobha Central",
      "sf_unit_prefix": "SC",
      "match_scope": "project",
      "buildingTransforms": {
        "The Eden at Sobha Central":    [ { "match": "^C(\\d+)$", "replace": "TE-$1" } ],
        "The Horizon at Sobha Central": [ { "match": "^D(\\d+)$", "replace": "TH-$1" } ]
      }
    },
    "Sobha Central Phase II": {
      "sf_project": "Sobha Central",
      "sf_unit_prefix": "SC",
      "match_scope": "project",
      "buildingTransforms": {
        "The Tranquil at Sobha Central": [ { "match": "^A(\\d+)$", "replace": "TQ-$1" } ],
        "The Serene at Sobha Central":   [ { "match": "^B(\\d+)$", "replace": "TS-$1" } ]
      }
    },
    "Sobha Central": {
      "sf_project": "Sobha Central",
      "sf_unit_prefix": "SC",
      "match_scope": "project",
      "buildingTransforms": {
        "The Pinnacle at Sobha Central": [ { "match": "^E-(\\d+)$", "replace": "PL-$1" } ],
        "The Mirage at Sobha Central":   [ { "match": "^F-(\\d+)$", "replace": "MG-$1" } ],
        "Sobha Central Mall":            [ { "match": "^R-(\\d+)$", "replace": "R-$1" } ]
      }
    },
    "Sobha Seahaven Tower B & C": {
      "sf_project": "Sobha SeaHaven",
      "sf_sub_project": "Sobha SeaHaven",
      "sf_unit_prefix": "SSH",
      "match_scope": "sub_project",
      "unitTransforms": []
    },
    "SKYSCAPE": {
      "sf_project": "Sobha Hartland -II",
      "match_scope": "project",
      "sf_unit_prefix": "",
      "buildingTransforms": {
        "Skyscape Altius": [ { "match": "^A(\\d+)$", "replace": "SAL-$1" } ],
        "Skyscape Aura":   [ { "match": "^C(\\d+)$", "replace": "SAR-$1" } ],
        "Skyscape Avenue": [ { "match": "^B(\\d+)$", "replace": "SAV-$1" } ]
      }
    },
    "Sobha Hartland - Crest Grande": {
      "sf_project": "Sobha Hartland",
      "sf_sub_project": "Crest Grande",
      "sf_unit_prefix": "",
      "match_scope": "sub_project",
      "unitTransforms": [
        { "match": "^([ABC])(\\d+)$", "replace": "CG$1$2" }
      ]
    },
    "SOBHA ONE": {
      "sf_project": "Sobha One",
      "match_scope": "project",
      "sf_unit_prefix": "",
      "buildingTransforms": {
        "Sobha One - A":      [ { "match": "^A(\\d+)$",         "replace": "SO-A$1"  } ],
        "Sobha One - B":      [ { "match": "^B(\\d+)$",         "replace": "SO-B$1"  } ],
        "Sobha One - C":      [ { "match": "^C(\\d+)$",         "replace": "SO-C$1"  } ],
        "Sobha One - D":      [ { "match": "^D(\\d+)$",         "replace": "SO-D$1"  } ],
        "Sobha One - E":      [ { "match": "^E(\\d+)$",         "replace": "SO-E$1"  } ],
        "Sobha One - Podium": [ { "match": "^([A-Z])(\\d+)$",   "replace": "SO-$1$2" } ]
      }
    },
    "Sobha Solis": {
      "sf_project": "Sobha Solis",
      "sf_sub_project": "Sobha Solis",
      "sf_unit_prefix": "",
      "match_scope": "sub_project",
      "buildingTransforms": {
        "Sobha Solis Tower A": [ { "match": "^A(\\d+)$", "replace": "SOL-A$1" } ],
        "Sobha Solis Tower B": [ { "match": "^B(\\d+)$", "replace": "SOL-B$1" } ],
        "Sobha Solis Tower C": [ { "match": "^C(\\d+)$", "replace": "SOL-C$1" } ],
        "Sobha Solis Tower D": [ { "match": "^D(\\d+)$", "replace": "SOL-D$1" } ]
      }
    },

    "310 Riverside Crescent": {
      "sf_project": "Sobha Hartland -II",
      "sf_sub_project": "310 Riverside Crescent",
      "sf_unit_prefix": "",
      "match_scope": "sub_project",
      "unitTransforms": [
        { "match": "^(\\d+)$",      "replace": "310 RSC-$1"   },
        { "match": "^310-R(\\d+)$", "replace": "310 RSC-R$1"  }
      ]
    },
    "320 Riverside Crescent": {
